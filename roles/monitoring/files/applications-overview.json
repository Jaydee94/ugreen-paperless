        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{job=\"cadvisor\", name!=\"\", name=~\".*paperless.*|.*gotify.*|.*opencode.*\"}[2m])) * 100",
          "instant": true,
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
